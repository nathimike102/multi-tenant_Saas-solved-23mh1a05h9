# Backend Environment Variables Template

# Environment
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@host:5432/nathi_saas

# JWT Configuration
JWT_SECRET=your-super-secret-key-here-change-this
JWT_EXPIRY=24h

# Password Hashing
BCRYPT_ROUNDS=10

# CORS Configuration
CORS_ORIGIN=https://multitenantsa3h.vercel.app
FRONTEND_URL=https://multitenantsa3h.vercel.app

# Server Configuration
PORT=5000
LOG_LEVEL=info

# Optional: Email Service (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@nathi.app
